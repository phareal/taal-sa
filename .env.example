# ─────────────────────────────────────────────────────────────────
# .env.example — Copier en .env et adapter les valeurs
# NE JAMAIS committer le fichier .env réel dans Git
# ─────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=production          # development | production
DOMAIN=dashboard.taal.tg        # domaine public (pour Nginx + certbot)
BUILD_TARGET=production         # production | development

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=taal_db
POSTGRES_USER=taal_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_PORT=6379

# ── Backend FastAPI ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
BACKEND_PORT=8000
LOG_LEVEL=info                  # debug | info | warning | error
CORS_ORIGINS=http://localhost:3000,https://dashboard.taal.tg
UPLOAD_MAX_SIZE_MB=50

# ── Frontend Nuxt.js ──────────────────────────────────────────────
FRONTEND_PORT=3000
NUXT_PUBLIC_API_BASE=https://dashboard.taal.tg
NODE_ENV=production

# ── Nginx ─────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── PgAdmin (profil tools) ────────────────────────────────────────
PGADMIN_EMAIL=admin@taal.tg
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_PORT=5050
